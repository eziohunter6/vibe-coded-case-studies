# ─── AI Chat (voice agent) ───────────────────────────────────────────────────
# Free tier at console.groq.com — no credit card required
GROQ_API_KEY=

# ─── Text-to-Speech (voice agent) ────────────────────────────────────────────
# Free tier at elevenlabs.io — ensure "text_to_speech" permission is enabled
ELEVENLABS_API_KEY=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used for OG meta tags. Set to your Vercel domain after first deploy.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
